# InferaVideo environment config
# Copy to .env and customise

# Whisper model size: tiny | base | small | medium | large
INFRA_WHISPER_MODEL=base

# Search backend: tfidf | embeddings
INFRA_SEARCH_BACKEND=tfidf

# Summarisation backend: extractive | transformers
INFRA_SUMMARISE_BACKEND=extractive

# Pipeline tuning
INFRA_HIGHLIGHT_THRESHOLD=0.75
INFRA_CHAPTER_THRESHOLD=1.3
INFRA_MAX_CLIP_DURATION=60
